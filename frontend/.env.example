# Aiqan Frontend Environment Variables
# Copy this file to .env and adjust values as needed.
# These are read at build time via EXPO_PUBLIC_* prefix.

# API Base URL — change to match your backend server address.
# Android emulator: http://10.0.2.2:5000/api
# iOS simulator:    http://localhost:5000/api
# Physical device:  http://YOUR_LOCAL_IP:5000/api
EXPO_PUBLIC_API_URL=http://192.168.100.8:5000/api

# Gemini API Key — get one free at https://ai.google.dev/
# When set, the AI assistant uses Gemini for ChatGPT-quality answers.
# Without it, the AI falls back to pre-written local responses.
EXPO_PUBLIC_GEMINI_API_KEY=
